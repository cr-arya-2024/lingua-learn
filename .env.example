# Lingo.dev API Key - Get from https://lingo.dev/dashboard
LINGO_API_KEY=your_lingo_dev_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_key
# Publishable key (safe to expose in the browser) - used by @stripe/stripe-js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs for premium plans (Dashboard → Products → select product → copy Price ID)
# TODO: Paste your price IDs below:
PRICE_MONTHLY=price_xxx
PRICE_YEARLY=price_xxx
PRICE_LIFETIME=price_xxx

# Session Secret
SESSION_SECRET=generate-a-random-secret-for-production
